{
  "manifest_version": 3,
  "name": "HCMUTE Downloader",
  "version": "2.2",
  "description": "Tải file PDF gốc từ thư viện số HCMUTE",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "*://*.hcmute.edu.vn/*"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "HCMUTE Downloader"
  },
  "content_scripts": [
    {
      "matches": ["*://*.hcmute.edu.vn/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}